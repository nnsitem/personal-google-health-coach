# Copy to .env and fill in. Never commit .env.

# --- LINE Messaging API (LINE Developers console > your channel) ---
LINE_CHANNEL_SECRET=           # Channel secret (Basic settings tab)
LINE_CHANNEL_ACCESS_TOKEN=     # Long-lived token (Messaging API tab > issue)
LINE_USER_ID=                  # Your user ID (shows in webhook first message, or Basic settings)

# --- Cloudflare Tunnel (only needed once webhook goes live) ---
CLOUDFLARE_TUNNEL_TOKEN=

# --- Gemini (Google AI) ---
GEMINI_API_KEY=

# --- Local testing ---
# Enables POST /chat (which is publicly reachable through the tunnel!) when set;
# requests must send the same value in an X-Chat-Token header. Leave empty to
# keep the endpoint disabled.
CHAT_TEST_TOKEN=

# --- General ---
TZ=Asia/Bangkok
